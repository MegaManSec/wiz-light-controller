# Reproducible, integrity-checked installs.
engine-strict=true
lockfile-include-tarball-url=true

# Supply-chain hardening: dependency lifecycle scripts are blocked by default in
# pnpm 10. The only package allowed to run one is esbuild (to build its native
# binary, used by `build:jscore`), allowlisted via `pnpm.onlyBuiltDependencies`
# in package.json.
